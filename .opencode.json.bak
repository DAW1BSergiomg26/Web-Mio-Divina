{
  "$schema": "https://opencode.ai/config.json",
  "providers": {
    "dockerLocal": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Docker Model Runner",
      "options": {
        "baseURL": "http://localhost:12434/v1",
        "apiKey": "dummy"
      },
      "models": {
        "llama-local": {
          "name": "ai/llama3.2"
        },
        "smollm-local": {
          "name": "ai/smollm2"
        }
      }
    },
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama Local",
      "options": {
        "baseURL": "http://localhost:11434/v1",
        "apiKey": "ollama"
      },
      "models": {
        "llama3": {
          "name": "llama3"
        },
        "llama3.1": {
          "name": "llama3.1"
        },
        "llama3.2": {
          "name": "llama3.2"
        },
        "llama2": {
          "name": "llama2"
        },
        "mistral": {
          "name": "mistral"
        },
        "codellama": {
          "name": "codellama"
        },
        "phi3": {
          "name": "phi3"
        }
      }
    },
    "openai": {
      "name": "OpenAI (Cloud)",
      "options": {
        "apiKey": "tu-api-key-aqui"
      },
      "models": {
        "gpt4o": {
          "name": "gpt-4o"
        },
        "gpt4o-mini": {
          "name": "gpt-4o-mini"
        },
        "gpt35-turbo": {
          "name": "gpt-3.5-turbo"
        }
      }
    }
  },
  "defaultModel": "ollama:llama3"
}